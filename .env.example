# Copy this file to .env and fill in your values.
# .env is git-ignored; .env.example is committed as a template.

# MinIO root credentials (used by the MinIO container and by DVC / s3fs)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# MinIO endpoint used by s3fs / DVC (no trailing slash)
MINIO_ENDPOINT=http://localhost:9000

# MLflow tracking server
MLFLOW_TRACKING_URI=http://localhost:5000

# Bucket name (must match ALLIUM_BUCKET and DVC remote URLs)
ALLIUM_BUCKET=allium-cepa-ml

# Storage backend: minio (default, for local dev) | s3 (real AWS)
ALLIUM_STORAGE=minio
