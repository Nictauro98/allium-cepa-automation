# Copy this file to .env and fill in your values.
# .env is git-ignored; .env.example is committed as a template.

# MinIO root credentials (used by the MinIO container and by DVC / s3fs)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# MinIO endpoint used by s3fs / DVC (no trailing slash)
MINIO_ENDPOINT=http://localhost:9000

# MLflow tracking server
MLFLOW_TRACKING_URI=http://localhost:5000

# Bucket name (must match ALLIUM_BUCKET and DVC remote URLs)
ALLIUM_BUCKET=allium-cepa-ml

# Storage backend: minio (default, for local dev) | s3 (real AWS)
ALLIUM_STORAGE=minio

# --- Ingestion provider switches (all default to mock; mocks need no secrets) ---
# ALLIUM_LABELING=zooniverse   # uncomment to use real Zooniverse
# ALLIUM_DRIVE=gdrive           # uncomment to use real Google Drive
# ALLIUM_HUB=hf                 # uncomment to use real HuggingFace

# Zooniverse (required when ALLIUM_LABELING=zooniverse)
# ZOONIVERSE_USERNAME=
# ZOONIVERSE_PASSWORD=
# ZOONIVERSE_PROJECT_ID=

# Google Drive (required when ALLIUM_DRIVE=gdrive)
# GOOGLE_DRIVE_CREDENTIALS_PATH=/path/to/service_account.json
# GOOGLE_DRIVE_FOLDER_ID=

# HuggingFace (required when ALLIUM_HUB=hf)
# HF_TOKEN=
# HF_DATASET_REPO=GIAR-UTN/allium-cepa-dataset
# HF_SPACE_ID=GIAR-UTN/allium-cepa-space

# Airflow webserver secret key (change in production)
AIRFLOW_SECRET_KEY=changeme
